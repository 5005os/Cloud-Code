[
  {
    "title": "Знакомство (Таанышуу)",
    "lines": [
      { "ky": "Салам! Кандайсың?", "ru": "Привет! Как дела?" },
      { "ky": "Жакшы, рахмат. Өзүң кандайсың?", "ru": "Хорошо, спасибо. А ты как?" },
      { "ky": "Менмин да жакшы. Менин атым Айбек. Сенин атың ким?", "ru": "Я тоже хорошо. Меня зовут Айбек. А тебя как зовут?" },
      { "ky": "Менин атым Нурлан. Таанышканыма кубанычтамын.", "ru": "Меня зовут Нурлан. Рад знакомству." }
    ]
  },
  {
    "title": "В магазине (Дүкөндө)",
    "lines": [
      { "ky": "Саламатсызбы! Бул канча турат?", "ru": "Здравствуйте! Сколько это стоит?" },
      { "ky": "Жүз сом.", "ru": "Сто сомов." },
      { "ky": "Кымбат экен. Арзаныраак болобу?", "ru": "Дорого. Можно дешевле?" },
      { "ky": "Мага бир нан жана сүт бериңизчи.", "ru": "Дайте мне один хлеб и молоко." },
      { "ky": "Мынакей. Рахмат, сатып алганыңызга!", "ru": "Вот. Спасибо за покупку!" }
    ]
  },
  {
    "title": "На улице (Көчөдө)",
    "lines": [
      { "ky": "Кечиресиз, базар кайда?", "ru": "Извините, где базар?" },
      { "ky": "Түз барыңыз, анан солго бурулуңуз.", "ru": "Идите прямо, потом поверните налево." },
      { "ky": "Алыспы?", "ru": "Это далеко?" },
      { "ky": "Жок, жакын. Рахмат!", "ru": "Нет, близко. Спасибо!" }
    ]
  },
  {
    "title": "В гостях (Конокто)",
    "lines": [
      { "ky": "Кош келиңиз! Төргө өтүңүз.", "ru": "Добро пожаловать! Проходите на почётное место." },
      { "ky": "Рахмат! Үйүңүз абдан жылуу экен.", "ru": "Спасибо! У вас очень тепло (уютно)." },
      { "ky": "Чай ичиңиз. Тамак даяр.", "ru": "Пейте чай. Еда готова." },
      { "ky": "Аш болсун! Абдан даамдуу.", "ru": "Приятного аппетита! Очень вкусно." }
    ]
  },
  {
    "title": "У врача (Дарыгерде)",
    "lines": [
      { "ky": "Саламатсызбы, дарыгер. Менин башым ооруйт.", "ru": "Здравствуйте, доктор. У меня болит голова." },
      { "ky": "Качантан бери ооруйт?", "ru": "Как давно болит?" },
      { "ky": "Кечээтен бери.", "ru": "Со вчерашнего дня." },
      { "ky": "Тынчыңызды алыңыз жана бул дарыны ичиңиз.", "ru": "Отдыхайте и принимайте это лекарство." }
    ]
  },
  {
    "title": "В кафе (Кафеде)",
    "lines": [
      { "ky": "Саламатсызбы! Меню бар бекен?", "ru": "Здравствуйте! Есть меню?" },
      { "ky": "Ооба, мынакей. Эмне буюртасыз?", "ru": "Да, вот. Что закажете?" },
      { "ky": "Мага бир лагман жана чай бериңизчи.", "ru": "Дайте мне один лагман и чай." },
      { "ky": "Азыр алып келем.", "ru": "Сейчас принесу." }
    ]
  },
  {
    "title": "По телефону (Телефондо)",
    "lines": [
      { "ky": "Алло, салам! Бул Айбекпи?", "ru": "Алло, привет! Это Айбек?" },
      { "ky": "Ооба, мен. Ким бул?", "ru": "Да, это я. Кто это?" },
      { "ky": "Бул мен, Нурлан. Бош убактың барбы?", "ru": "Это я, Нурлан. Есть свободное время?" },
      { "ky": "Ооба, айт.", "ru": "Да, говори." }
    ]
  },
  {
    "title": "В аэропорту (Аэропортто)",
    "lines": [
      { "ky": "Кечиресиз, каттоо кайда?", "ru": "Извините, где регистрация?" },
      { "ky": "Паспортуңузду көрсөтүңүз.", "ru": "Покажите ваш паспорт." },
      { "ky": "Учак канчада учат?", "ru": "Когда вылетает самолёт?" },
      { "ky": "Саат ондо учат.", "ru": "Вылетает в десять часов." }
    ]
  },
  {
    "title": "В гостинице (Мейманканада)",
    "lines": [
      { "ky": "Саламатсызбы! Бош бөлмө барбы?", "ru": "Здравствуйте! Есть свободный номер?" },
      { "ky": "Ооба, бар. Канча күнгө?", "ru": "Да, есть. На сколько дней?" },
      { "ky": "Эки күнгө.", "ru": "На два дня." },
      { "ky": "Жакшы, паспортуңузду бериңиз.", "ru": "Хорошо, дайте паспорт." }
    ]
  },
  {
    "title": "На работе (Жумушта)",
    "lines": [
      { "ky": "Кутмандуу таң! Жумушка кеч калдыңбы?", "ru": "Доброе утро! Ты опоздал на работу?" },
      { "ky": "Жок, өз убагында келдим.", "ru": "Нет, пришёл вовремя." },
      { "ky": "Бул отчётту бүгүн бүтүр.", "ru": "Закончи этот отчёт сегодня." },
      { "ky": "Макул, азыр баштайм.", "ru": "Хорошо, сейчас начну." }
    ]
  }
]
